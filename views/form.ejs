<!DOCTYPE html>
<html>
<head>
    
    <title>Create Portfolio</title>
    <link rel="stylesheet" href="/CSS/style.css">
</head>
<body>
    <h1>Create Your Portfolio</h1>
    <form action="/portfolio" method="POST">

    <input name="name" placeholder="Name" required>
    <input name="username" placeholder="Username" required>
    <input name="title" placeholder="Title">
    <textarea name="about" placeholder="About"></textarea>
    <input name="skills" placeholder="Skills">
    
    <h3> Projects</h3>
    <input name="projectName1" placeholder="Project 1 Name">
    <input name="projectLink1" placeholder="Project 1 Link">
    <input name="projectName2" placeholder="Project 2 Name">
    <input name="projectLink2" placeholder="Project 2 Link">

    <input name="github" placeholder="GitHub">
    <input name="linkedin" placeholder="LinkedIn">

    <button type="submit">Create Portfolio</button>
    </form>

</body>
</html>
